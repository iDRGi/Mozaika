# Скопируйте в .env и заполните реальными значениями

# База данных
DATABASE_URI=postgresql://mozaika:ЗАМЕНИТЕ_ПАРОЛЬ@postgres:5432/mozaika
POSTGRES_PASSWORD=ЗАМЕНИТЕ_ПАРОЛЬ

# Payload CMS — секретный ключ (минимум 32 символа, сгенерируйте: openssl rand -hex 32)
PAYLOAD_SECRET=ЗАМЕНИТЕ_СЕКРЕТ

# URL сайта (без слэша в конце)
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com
